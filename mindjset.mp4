<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MINDJSET</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html, body{
width:100%;
height:100%;
overflow:hidden;
background:black;
font-family:Georgia, serif;
}

.video-bg{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
object-fit:cover;
z-index:-2;
background:black;
}

.overlay{
position:fixed;
inset:0;
background:rgba(0,0,0,0.20);
z-index:-1;
}

.container{
position:absolute;
top:60%;
left:50%;
transform:translate(-50%,-50%);
display:flex;
flex-direction:column;
align-items:center;
text-align:center;
width:90%;
}

.logo{
max-width:65%;
height:auto;
margin-bottom:35px;
}

.text{
color:white;
font-style:italic;
font-size:22px;
letter-spacing:2px;
margin-bottom:15px;
}

.dots{
display:flex;
gap:10px;
margin-bottom:30px;
}

.dot{
width:6px;
height:6px;
border-radius:50%;
background:white;
animation:pulse 1.6s ease-in-out infinite;
}

.dot:nth-child(2){
animation-delay:0.2s;
}

.dot:nth-child(3){
animation-delay:0.4s;
}

.instagram img{
width:28px;
height:28px;
opacity:0.8;
transition:0.3s;
}

.instagram img:hover{
opacity:1;
transform:scale(1.1);
}

@keyframes pulse{
0%,100%{
opacity:0.3;
transform:scale(0.9);
}
50%{
opacity:1;
transform:scale(1.3);
}
}

@media (max-width:768px){
.logo{
max-width:85%;
}
.text{
font-size:18px;
}
}

</style>

</head>

<body>

<video class="video-bg" autoplay muted loop playsinline preload="auto">
  <source src="mindjset.mp4" type="video/mp4">
</video>

<div class="overlay"></div>

<div class="container">

  <img src="ffa8137b-45e1-430b-b761-9beff61c17cb.jpeg" class="logo" alt="Mindjset logo">

  <div class="text">Launching soon</div>

  <div class="dots">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>

  <div class="instagram">
    <a href="instagram://user?username=mindjset" onclick="setTimeout(function(){ window.location='https://www.instagram.com/mindjset'; }, 500)">
      <img src="https://cdn-icons-png.flaticon.com/512/2111/2111463.png" alt="Instagram">
    </a>
  </div>

</div>

</body>

</html>
